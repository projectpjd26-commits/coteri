# Supabase
# Get these from Supabase Dashboard → Project Settings → API. Use the exact Project URL (e.g. https://abcdefgh.supabase.co, no trailing slash).
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-publishable-key
STRIPE_PRICE_ID=your-price-id
# If using Stripe via Supabase Edge Function, set Edge secrets in Supabase Dashboard (e.g. STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET). See STRIPE-WEBHOOK-RUNBOOK.md.

# App (redirects, logout, set-venue, demo grant)
# Use actual Vercel URL in production (e.g. https://coteri.vercel.app).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: comma-separated user UUIDs for admin / grant membership (alternative to PERMANENT_ADMINS in code).
# INTERNAL_DEMO_USER_IDS=uuid1,uuid2

# Optional: QR signing secret for pass verification (if used).
# QR_SIGNING_SECRET=your-secret

# AI Analytics / Venue Copilot (optional). Use one of:
# - Ollama (free, local): set OLLAMA_BASE_URL (e.g. http://localhost:11434); optional OLLAMA_MODEL (default llama3.2).
# - Anthropic (paid): set ANTHROPIC_API_KEY. Used when OLLAMA_BASE_URL is not set.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Demo: set IS_DEMO_MODE=true to enable /internal/demo, demo-reset, demo-grant, and mock fallback venues.
# Leave unset or false for production.
# IS_DEMO_MODE=true

# Apple Wallet
APPLE_TEAM_ID=your-apple-team-id
APPLE_PASS_TYPE_ID=pass.com.yourcompany.membership
APPLE_SIGNING_CERT_PATH=./certs/apple-pass-signing.pem
APPLE_WWDR_CERT_PATH=./certs/AppleWWDRCA.pem

# Google Wallet  
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_ISSUER_ID=your-issuer-id
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./keys/google-service-account.json

# Next.js (legacy / Stripe success URLs in app-legacy; prefer NEXT_PUBLIC_SITE_URL for app routes)
NEXT_PUBLIC_BASE_URL=https://yourdomain.com
